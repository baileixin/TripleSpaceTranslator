<Window
    x:Class="TripleSpaceTranslator.App.Windows.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TripleSpaceTranslator 设置"
    Width="680"
    Height="760"
    MinWidth="680"
    MinHeight="760"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CheckBox
            Grid.Row="0"
            Margin="0,0,0,12"
            Content="开机自动启动"
            IsChecked="{Binding RunAtStartup}" />

        <CheckBox
            Grid.Row="1"
            Margin="0,0,0,20"
            Content="显示错误通知"
            IsChecked="{Binding NotificationsEnabled}" />

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="默认目标语言" />
            <ComboBox
                Grid.Column="1"
                DisplayMemberPath="DisplayName"
                ItemsSource="{Binding AvailableLanguages}"
                SelectedItem="{Binding SelectedLanguage}" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Top" Text="触发快捷键" />
            <StackPanel Grid.Column="1">
                <WrapPanel Margin="0,0,0,8">
                    <CheckBox Margin="0,0,12,0" Content="Ctrl" IsChecked="{Binding TriggerCtrl}" />
                    <CheckBox Margin="0,0,12,0" Content="Alt" IsChecked="{Binding TriggerAlt}" />
                    <CheckBox Margin="0,0,12,0" Content="Shift" IsChecked="{Binding TriggerShift}" />
                    <CheckBox Content="Win" IsChecked="{Binding TriggerWin}" />
                </WrapPanel>
                <ComboBox
                    Width="180"
                    DisplayMemberPath="DisplayName"
                    ItemsSource="{Binding AvailableShortcutKeys}"
                    SelectedItem="{Binding SelectedShortcutKey}" />
                <TextBlock Margin="0,8,0,0" Foreground="Gray" Text="{Binding HotkeyDisplayText}" />
                <TextBlock
                    Margin="0,4,0,0"
                    Foreground="Gray"
                    Text="建议至少保留 Ctrl 或 Alt，避免和正常输入冲突。"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="翻译服务" />
            <ComboBox
                Grid.Column="1"
                DisplayMemberPath="DisplayName"
                ItemsSource="{Binding AvailableProviders}"
                SelectedItem="{Binding SelectedProvider}" />
        </Grid>

        <StackPanel Grid.Row="5" Margin="120,0,0,16">
            <TextBlock Foreground="Gray" Text="{Binding ProviderDescription}" TextWrapping="Wrap" />
            <CheckBox
                Margin="0,10,0,0"
                Content="显示高级设置"
                IsChecked="{Binding ShowAdvancedProviderSettings}"
                Visibility="{Binding ShowAdvancedProviderSettingsToggle, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </StackPanel>

        <Grid Grid.Row="6" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="超时（秒）" />
            <TextBox Grid.Column="1" Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Grid
            Grid.Row="7"
            Margin="0,0,0,12"
            Visibility="{Binding ShowRegionSettings, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="Region" />
            <TextBox Grid.Column="1" Text="{Binding Region, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Grid
            Grid.Row="8"
            Margin="0,0,0,12"
            Visibility="{Binding ShowProjectIdSettings, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="ProjectId" />
            <TextBox Grid.Column="1" Text="{Binding ProjectId, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Grid Grid.Row="9" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" Text="{Binding CredentialIdLabel}" />
            <TextBox
                Grid.Column="1"
                FontFamily="Consolas"
                Text="{Binding SecretId, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock
                Grid.Row="1"
                Margin="0,12,0,0"
                VerticalAlignment="Center"
                Text="{Binding CredentialKeyLabel}" />
            <TextBox
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,12,0,0"
                FontFamily="Consolas"
                Text="{Binding SecretKey, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <Grid Grid.Row="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" Text="连接测试" />
            <TextBlock
                Grid.Column="1"
                Margin="0,0,12,0"
                VerticalAlignment="Center"
                Text="{Binding ProviderConnectionTestHint}"
                TextWrapping="Wrap" />
            <Button
                Grid.Column="2"
                Width="100"
                Command="{Binding TestConnectionCommand}"
                Content="测试连接" />

            <TextBlock
                Grid.Row="1"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="0,12,0,0"
                Text="{Binding ConnectionStatusMessage}"
                TextWrapping="Wrap" />

            <TextBlock
                Grid.Row="2"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="0,8,0,0"
                Foreground="Gray"
                Text="不需要先保存，测试连接会直接使用当前界面里的配置。"
                TextWrapping="Wrap" />
        </Grid>

        <StackPanel
            Grid.Row="11"
            Margin="0,20,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Margin="0,0,12,0"
                Command="{Binding SaveCommand}"
                Content="保存" />
            <Button
                Width="100"
                Command="{Binding CloseCommand}"
                Content="关闭" />
        </StackPanel>
    </Grid>
</Window>
